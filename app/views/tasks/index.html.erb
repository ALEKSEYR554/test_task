<h1>Задачи</h1>

<%= link_to 'Новая задача', new_task_path, class: 'btn' %>

<table>
  <thead>
    <tr>
      <th>Название</th>
      <th>Дата выполнения</th>
      <th>Статус</th>
      <th>Тип</th>
      <th>Теги</th>
      <th>Действия</th>
    </tr>
  </thead>
  <tbody>
    <% @tasks.each do |task| %>
      <tr>
        <td><%= task.title %></td>
        <td><%= task.due_date.strftime('%d.%m.%Y %H:%M') %></td>
        <td><%= task.status_label %></td>
        <td><%= task.task_type_label %></td>
        <td>
          <% task.tags.each do |tag| %>
            <span style="background-color: <%= tag.color %>; color: white; padding: 2px 6px; border-radius: 3px; margin-right: 4px;">
              <%= tag.name %>
            </span>
          <% end %>
        </td>
        <td>
          <%= link_to 'Просмотр', task %> |
          <%= link_to 'Редактировать', edit_task_path(task) %> |
          <%= link_to 'Удалить', task, data: { turbo_method: :delete, turbo_confirm: 'Вы уверены?' } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>