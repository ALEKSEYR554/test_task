<%= form_with(model: [:admin, user]) do |f| %>
  <% if user.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(user.errors.count, "ошибка") %> при сохранении пользователя:</h2>
      <ul>
        <% user.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= f.label :name, "Имя" %>
    <%= f.text_field :name %>
  </div>

  <div class="form-group">
    <%= f.label :email, "Электронная почта" %>
    <%= f.email_field :email %>
  </div>

  <div class="form-group">
    <%= f.label :password, "Пароль" %>
    <%= f.password_field :password %>
  </div>

  <div class="form-group">
    <%= f.label :password_confirmation, "Подтверждение пароля" %>
    <%= f.password_field :password_confirmation %>
  </div>

  <div class="form-group">
    <%= f.label :role, "Роль" %>
    <%= f.select :role, ['admin', 'user'] %>
  </div>

  <div class="actions">
    <%= f.submit class: 'btn' %>
  </div>
<% end %>