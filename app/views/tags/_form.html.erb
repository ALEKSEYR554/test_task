<%= form_with(model: tag) do |f| %>
  <% if tag.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(tag.errors.count, "ошибка") %> при сохранении тега:</h2>
      <ul>
        <% tag.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= f.label :name, "Название" %>
    <%= f.text_field :name %>
  </div>

  <div class="form-group">
    <%= f.label :color, "Цвет" %>
    <%= f.color_field :color %>
  </div>

  <div class="actions">
    <%= f.submit class: 'btn' %>
  </div>
<% end %>