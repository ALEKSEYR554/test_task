<h1>Теги</h1>

<%= link_to 'Новый тег', new_tag_path, class: 'btn' %>

<table>
  <thead>
    <tr>
      <th>Название</th>
      <th>Цвет</th>
      <th>Обязательный</th>
      <th>Действия</th>
    </tr>
  </thead>
  <tbody>
    <% @tags.each do |tag| %>
      <tr>
        <td><%= tag.name %></td>
        <td>
          <span style="background-color: <%= tag.color %>; color: white; padding: 2px 6px; border-radius: 3px;">
            <%= tag.color %>
          </span>
        </td>
        <td><%= tag.required? ? 'Да' : 'Нет' %></td>
        <td>
          <%= link_to 'Просмотр', tag %>
          <% unless tag.required? %>
            | <%= link_to 'Редактировать', edit_tag_path(tag) %>
            | <%= link_to 'Удалить', tag, data: { turbo_method: :delete, turbo_confirm: 'Вы уверены?' } %>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>